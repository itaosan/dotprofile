{
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(cargo:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Read(**)",
      "Edit(~/**)",
      "WebFetch(domain:*)",
      "Grep(**)",
      "Glob(**)",
      "LS(**)"
    ],
    "deny": [
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(python -m pip:*)",
      "Bash(python3 -m pip:*)",
      "Bash(rm -rf /)",
      "Bash(sudo rm:*)",
      "Bash(format:*)",
      "Read(node_modules/**)",
      "Read(.git/**)",
      "Read(*.log)",
      "Read(dist/**)",
      "Read(build/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/gh-setup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c 'if .tool_input.command | test(\"rm -rf|dd if=|:(){ :|:& };:\") then {\"decision\": \"block\", \"reason\": \"危険なコマンドは実行できません。別の方法を検討してください。\"} else empty end'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotprofile/ai-coding/notify.sh -t 'Claude Code' -m 'タスクが終わりました'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "ralph-wiggum@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "duckdb-skills@duckdb-skills": true,
    "feature-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "duckdb-skills": {
      "source": {
        "source": "github",
        "repo": "duckdb/duckdb-skills"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "./docs/plans",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto",
  "model": "opus[1m]"
}
